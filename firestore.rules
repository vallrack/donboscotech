
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Funciones de utilidad para verificación de identidad y roles
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)); }
    function isCoordinator() { return isSignedIn() && exists(/databases/$(database)/documents/roles_coordinators/$(request.auth.uid)); }
    function isSecretary() { return isSignedIn() && exists(/databases/$(database)/documents/roles_secretaries/$(request.auth.uid)); }
    function isPrivileged() { return isAdmin() || isCoordinator() || isSecretary(); }

    // Anuncios: Lectura permitida para todos los autenticados, escritura solo privilegiados
    match /announcements/{id} {
      allow read: if isSignedIn();
      allow write: if isPrivileged();
    }

    // ACCESO SIN RESTRICCIONES PARA ADMIN Y COORDINADOR (Excepto donde se especifique lo contrario)
    match /{document=**} {
      allow read, write: if isAdmin() || isCoordinator();
    }

    // Perfiles de usuario y asistencia
    match /userProfiles/{userId} {
      allow read: if true; 
      allow create, update: if isSignedIn() && (request.auth.uid == userId || isPrivileged());
      allow delete: if isAdmin() || isCoordinator();

      match /attendanceRecords/{recordId} {
        allow create, read: if true; 
        allow update: if isSignedIn() && (request.auth.uid == userId || isPrivileged());
        allow delete: if isAdmin() || isCoordinator();
      }
    }

    // Historial global de asistencia
    match /globalAttendanceRecords/{recordId} {
      allow create: if true; 
      allow read: if isSignedIn() && (isPrivileged() || exists(/databases/$(database)/documents/userProfiles/$(request.auth.uid)));
      allow update, delete: if isAdmin() || isCoordinator();
    }
    
    // Colecciones de roles
    match /roles_admins/{userId} { allow read: if isSignedIn(); allow write: if isAdmin() || isCoordinator(); }
    match /roles_coordinators/{userId} { allow read: if isSignedIn(); allow write: if isAdmin() || isCoordinator(); }
    match /roles_secretaries/{userId} { allow read: if isSignedIn(); allow write: if isAdmin() || isCoordinator(); }
    
    // Configuración institucional
    match /campuses/{id} { allow read: if true; allow write: if isAdmin() || isCoordinator(); }
    match /programs/{id} { allow read: if true; allow write: if isAdmin() || isCoordinator(); }
    match /shifts/{id} { allow read: if true; allow write: if isAdmin() || isCoordinator(); }
  }
}
