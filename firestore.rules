
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() { return request.auth != null; }
    function isAdmin() { return isSignedIn() && exists(/databases/$(database)/documents/roles_admins/$(request.auth.uid)); }
    function isCoordinator() { return isSignedIn() && exists(/databases/$(database)/documents/roles_coordinators/$(request.auth.uid)); }
    function isSecretary() { return isSignedIn() && exists(/databases/$(database)/documents/roles_secretaries/$(request.auth.uid)); }
    function isPrivileged() { return isAdmin() || isCoordinator() || isSecretary(); }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }

    match /userProfiles/{userId} {
      allow read: if true; // Permite lectura para identificar carnet en terminal pública
      allow create: if isPrivileged() || isOwner(userId);
      allow update: if isAdmin() || (isCoordinator() && request.resource.data.role != 'admin') || (isOwner(userId) && (request.resource.data.role == resource.data.role || !('role' in request.resource.data)));
      allow delete: if isAdmin();

      match /attendanceRecords/{recordId} {
        // Permite creación desde terminal pública (sin sesión) si es un registro de asistencia válido
        allow create: if true; 
        allow read, update: if isPrivileged() || isOwner(userId);
        allow delete: if isAdmin();
      }
    }

    match /roles_admins/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /roles_coordinators/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isCoordinator();
    }

    match /roles_secretaries/{userId} {
      allow read: if isSignedIn();
      allow write: if isAdmin() || isCoordinator();
    }

    match /globalAttendanceRecords/{recordId} {
      // Permite creación pública para la terminal institucional
      allow create: if true;
      allow read: if isPrivileged();
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }
    
    match /campuses/{id} {
      allow read: if true;
      allow write: if isPrivileged();
    }
    
    match /programs/{id} {
      allow read: if true;
      allow write: if isPrivileged();
    }
    
    match /shifts/{id} {
      allow read: if true;
      allow write: if isPrivileged();
    }
  }
}
