
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Información detallada del personal incluyendo datos institucionales.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["docent", "coordinator", "secretary", "admin"] },
        "documentId": { "type": "string", "description": "Documento de identidad" },
        "campus": { "type": "string", "description": "Sede asignada" },
        "program": { "type": "string", "description": "Programa o carrera que enseña/coordina" },
        "shiftId": { "type": "string", "description": "ID de la jornada asignada" },
        "avatarUrl": { "type": "string" },
        "status": { "type": "string", "enum": ["active", "inactive"] }
      },
      "required": ["name", "email", "role", "documentId", "campus", "program"]
    },
    "Campus": {
      "title": "Campus",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "address": { "type": "string" }
      }
    },
    "Program": {
      "title": "Program",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "type": { "type": "string", "enum": ["Technical", "Academic", "Administrative"] }
      }
    },
    "Shift": {
      "title": "Shift",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "days": { "type": "array", "items": { "type": "string" } }
      }
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/userProfiles/{userId}": { "schema": "UserProfile", "description": "Perfiles de usuario." },
    "/campuses/{id}": { "schema": "Campus", "description": "Sedes institucionales." },
    "/programs/{id}": { "schema": "Program", "description": "Carreras o programas." },
    "/shifts/{id}": { "schema": "Shift", "description": "Jornadas y horarios." },
    "/globalAttendanceRecords/{recordId}": { "schema": "AttendanceRecord", "description": "Historial global." }
  }
}
