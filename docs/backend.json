
{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Information about docents, coordinators, secretaries, and admins.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "role": { "type": "string", "enum": ["docent", "coordinator", "secretary", "admin"] },
        "avatarUrl": { "type": "string" }
      },
      "required": ["name", "email", "role"]
    },
    "AttendanceRecord": {
      "title": "Attendance Record",
      "description": "A single entry or exit event for a docent.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "date": { "type": "string" },
        "time": { "type": "string" },
        "type": { "type": "string", "enum": ["entry", "exit"] },
        "method": { "type": "string", "enum": ["QR", "Manual"] },
        "location": {
          "type": "object",
          "properties": {
            "lat": { "type": "number" },
            "lng": { "type": "number" },
            "address": { "type": "string" }
          }
        }
      },
      "required": ["userId", "userName", "date", "time", "type", "method"]
    }
  },
  "auth": {
    "providers": ["google.com", "password"]
  },
  "firestore": {
    "/userProfiles/{userId}": {
      "schema": "UserProfile",
      "description": "Primary user profiles collection."
    },
    "/userProfiles/{userId}/attendanceRecords/{recordId}": {
      "schema": "AttendanceRecord",
      "description": "Attendance history per user."
    },
    "/roles_admins/{userId}": {
      "schema": "object",
      "description": "User IDs that have administrative privileges."
    },
    "/roles_coordinators/{userId}": {
      "schema": "object",
      "description": "User IDs that have coordinator privileges."
    },
    "/roles_secretaries/{userId}": {
      "schema": "object",
      "description": "User IDs that have secretary privileges."
    },
    "/globalAttendanceRecords/{recordId}": {
      "schema": "AttendanceRecord",
      "description": "Consolidated view of all attendance records."
    }
  }
}
